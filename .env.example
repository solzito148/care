# ==========================================================================
# CARE — Plantilla de variables de entorno
# --------------------------------------------------------------------------
# Copia este archivo a `.env.local` (desarrollo) y carga las mismas claves en
# Vercel (produccion). NUNCA pongas valores reales aca: este archivo SE COMMITEA.
#
# Convencion:
#   NEXT_PUBLIC_*  -> se exponen al navegador (NO usar para secretos).
#   El resto       -> solo servidor (secretos: tokens, service role, etc.).
# ==========================================================================

# --- Publicas (van al navegador) -----------------------------------------
NEXT_PUBLIC_APP_NAME=CARE
NEXT_PUBLIC_DEFAULT_LOCALE=es-AR
# Dominio publico de la app. En produccion: https://tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Origin de fallback en SSR/scripts cuando no hay `window`.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase --------------------------------------------------------------
# Publicas (seguras de exponer):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SECRETO server-only: ignora RLS. Solo en webhooks/jobs de confianza.
SUPABASE_SERVICE_ROLE_KEY=
# SECRETO (opcional): para validar/forjar JWT en scripts backend.
SUPABASE_JWT_SECRET=
# SECRETO (opcional): conexion directa a Postgres para scripts/migraciones.
DATABASE_URL=

# --- Pagos: Mercado Pago ---------------------------------------------------
# SECRETO server-only. Sin token, el flujo de planes queda en "pendiente-pago"
# (activacion manual desde el panel admin).
MERCADOPAGO_ACCESS_TOKEN=
# SECRETO server-only. OBLIGATORIO en produccion: sin el, el webhook responde
# 503 (fail-closed) para no aceptar pagos sin verificar la firma.
MERCADOPAGO_WEBHOOK_SECRET=

# --- Notificaciones --------------------------------------------------------
# Email via Resend (https://resend.com). Sin API key se simula en consola.
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=CARE <no-reply@care.app>
# WhatsApp Cloud API. Sin token se simula en consola.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Observabilidad --------------------------------------------------------
# SECRETO (opcional): DSN de Sentry para captura de errores.
SENTRY_DSN=

# --- AWS (fases futuras) ---------------------------------------------------
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# SECRETOS server-only:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
