# App
NEXT_PUBLIC_APP_NAME=CARE
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=es-AR

# Origin usado como fallback en SSR / scripts cuando no hay `window`.
# En el browser CARE toma window.location.origin automaticamente.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Database (optional direct URL for scripts/backends)
DATABASE_URL=

# Notifications
# Email via Resend (https://resend.com). Sin API key se simula en consola.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=CARE <no-reply@care.app>

# Payments (Mercado Pago). Sin access token el flujo de planes queda en
# "pendiente-pago" (activacion manual desde el panel admin).
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# AWS (future phases)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability
SENTRY_DSN=
