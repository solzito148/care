# Supabase (provision via: vercel integration add supabase && vercel env pull .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dev test users (create in Supabase Auth dashboard, then assign roles via supabase/seed.sql):
# tutor@care.dev       -> role: tutor
# caregiver@care.dev   -> role: caregiver
# professional@care.dev -> role: professional
# legal@care.dev       -> role: legal_admin
# provider@care.dev    -> role: provider
